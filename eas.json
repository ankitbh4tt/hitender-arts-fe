{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },

  "build": {
    "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },

    "production": {
    "channel": "production",
      "android": {
